{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/merchant_contacted_mode",
  "title": "Merchant Contacted Method",
  "type": "string",
  "minLength": 1,
  "maxLength": 255,
  "pattern": "^[0-9A-Z_]+$",
  "description": "The method used to contact the merchant.",
  "enum": [
    "WEBSITE",
    "PHONE",
    "EMAIL",
    "WRITTEN",
    "IN_PERSON"
  ]
}