{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/merchant_contacted_outcome",
  "title": "Merchant Contacted Outcome",
  "type": "string",
  "minLength": 1,
  "maxLength": 255,
  "pattern": "^[0-9A-Z_]+$",
  "description": "The outcome when the customer has contacted the merchant.",
  "enum": [
    "NO_RESPONSE",
    "FIXED",
    "NOT_FIXED"
  ]
}